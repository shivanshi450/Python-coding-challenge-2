# Input string
text = input("Enter a string: ")

count = {}
duplicates = []

# Count characters
for ch in text:
    if ch in count:
        count[ch] += 1
    else:
        count[ch] = 1

# Find duplicates
for ch in count:
    if count[ch] > 1:
        duplicates.append(ch)

# Output
print("Duplicate characters:", " ".join(duplicates))
